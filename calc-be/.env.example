# Required: Google AI Studio API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_api_key_here

# Optional: override Gemini model (recommended if you get 404 model not found)
# Example: GEMINI_MODEL=gemini-2.5-flash
# If unset, the server will auto-pick the first working model from a fallback chain.
GEMINI_MODEL=

# Optional: server bind / port (defaults work for local dev)
SERVER_URL=localhost
PORT=8900

# Set to "dev" to enable permissive CORS and uvicorn reload.
ENV=dev

# Comma-separated list of additional allowed origins for production CORS.
# Example: ALLOWED_ORIGINS=https://aicalc.example.com,https://www.example.com
ALLOWED_ORIGINS=https://ai-calc-dusky.vercel.app,https://aicalc-nvif.onrender.com
